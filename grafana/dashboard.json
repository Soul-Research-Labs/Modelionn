{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Requests/sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(zkml_http_requests_total[1m])",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "title": "Request Latency (avg)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(zkml_http_request_duration_seconds_sum[1m]) / rate(zkml_http_request_duration_seconds_count[1m])",
          "legendFormat": "avg latency"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "In-Flight Requests",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "zkml_http_requests_in_flight",
          "legendFormat": "in-flight"
        }
      ]
    },
    {
      "title": "Proofs Generated",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "zkml_proofs_generated_total",
          "legendFormat": "total"
        }
      ]
    },
    {
      "title": "Circuits Uploaded",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "zkml_circuits_uploaded_total",
          "legendFormat": "total"
        }
      ]
    },
    {
      "title": "Active Miners / Validators",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "zkml_active_miners",
          "legendFormat": "miners"
        },
        {
          "expr": "zkml_active_validators",
          "legendFormat": "validators"
        }
      ]
    },
    {
      "title": "Proof Latency (avg)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(zkml_proof_latency_seconds_sum[5m]) / rate(zkml_proof_latency_seconds_count[5m])",
          "legendFormat": "avg"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Upload Size (bytes)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(zkml_upload_size_bytes_sum[5m])",
          "legendFormat": "bytes/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Request Latency P99",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(zkml_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P99"
        },
        {
          "expr": "histogram_quantile(0.95, rate(zkml_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Proof Job Queue Depth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "zkml_proof_jobs_queued",
          "legendFormat": "queued"
        },
        {
          "expr": "zkml_proof_jobs_proving",
          "legendFormat": "proving"
        },
        {
          "expr": "zkml_proof_jobs_aggregating",
          "legendFormat": "aggregating"
        }
      ]
    },
    {
      "title": "Proof Aggregation Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "rate(zkml_proof_aggregation_seconds_sum[5m]) / rate(zkml_proof_aggregation_seconds_count[5m])",
          "legendFormat": "avg aggregation"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Celery Worker Queue Length",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "celery_active_count",
          "legendFormat": "active tasks"
        },
        {
          "expr": "celery_reserved_count",
          "legendFormat": "reserved tasks"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["zkml", "bittensor"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "ZKML ZK Prover Network",
