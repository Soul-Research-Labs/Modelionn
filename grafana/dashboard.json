{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Requests/sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(modelionn_http_requests_total[1m])",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "title": "Request Latency (avg)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(modelionn_http_request_duration_seconds_sum[1m]) / rate(modelionn_http_request_duration_seconds_count[1m])",
          "legendFormat": "avg latency"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "In-Flight Requests",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "modelionn_http_requests_in_flight",
          "legendFormat": "in-flight"
        }
      ]
    },
    {
      "title": "Proofs Generated",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "modelionn_proofs_generated_total",
          "legendFormat": "total"
        }
      ]
    },
    {
      "title": "Circuits Uploaded",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "modelionn_circuits_uploaded_total",
          "legendFormat": "total"
        }
      ]
    },
    {
      "title": "Active Miners / Validators",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "modelionn_active_miners",
          "legendFormat": "miners"
        },
        {
          "expr": "modelionn_active_validators",
          "legendFormat": "validators"
        }
      ]
    },
    {
      "title": "Proof Latency (avg)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(modelionn_proof_latency_seconds_sum[5m]) / rate(modelionn_proof_latency_seconds_count[5m])",
          "legendFormat": "avg"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Upload Size (bytes)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(modelionn_upload_size_bytes_sum[5m])",
          "legendFormat": "bytes/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["modelionn", "bittensor"],
  "templating": { "list": [] },
