# ─── Modelionn Registry ────────────────────────────────────
# All settings use the MODELIONN_ prefix.
# Copy this file to .env and fill in values for your environment.

# API
MODELIONN_API_HOST=0.0.0.0
MODELIONN_API_PORT=8000
MODELIONN_DEBUG=false
MODELIONN_SECRET_KEY=change-me-use-64-chars-minimum-random-string

# Database (async SQLAlchemy URL)
MODELIONN_DATABASE_URL=sqlite+aiosqlite:///./data/modelionn.db

# IPFS
MODELIONN_IPFS_API_URL=http://127.0.0.1:5001
MODELIONN_IPFS_GATEWAY_URL=http://127.0.0.1:8080

# Redis (cache)
MODELIONN_REDIS_URL=redis://localhost:6379/0

# Celery (async proof dispatch pipeline)
MODELIONN_CELERY_BROKER_URL=redis://localhost:6379/1
MODELIONN_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Bittensor
MODELIONN_BT_NETWORK=test
MODELIONN_BT_NETUID=1
MODELIONN_BT_WALLET_NAME=default
MODELIONN_BT_WALLET_HOTKEY=default
MODELIONN_MIN_STAKE_TO_PUBLISH=0.0

# Field encryption (AES-256-GCM) — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MODELIONN_ENCRYPTION_KEY=

# CORS (comma-separated origins for the web dashboard)
MODELIONN_CORS_ORIGINS=http://localhost:3000

# ─── Sentry (optional) ────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_RATE=0.1
SENTRY_PROFILES_RATE=0.1

# ─── Next.js Dashboard ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production
