FROM python:3.12-slim AS base

WORKDIR /app
COPY pyproject.toml README.md ./
COPY registry/ registry/
COPY subnet/ subnet/
COPY evaluation/ evaluation/
COPY sdk/ sdk/
COPY cli/ cli/

RUN pip install --no-cache-dir -e ".[bittensor]"

# Miner
FROM base AS miner
ENTRYPOINT ["python", "-m", "subnet.neurons.miner"]

# Validator
FROM base AS validator
ENTRYPOINT ["python", "-m", "subnet.neurons.validator"]
