# ─── Modelionn Production Environment ──────────────────────
# Copy to .env and fill in ALL values before deploying.
# See docs/tls-setup.md for HTTPS configuration.

# ── API ──────────────────────────────────────────────────────
MODELIONN_API_HOST=0.0.0.0
MODELIONN_API_PORT=8000
MODELIONN_DEBUG=false
MODELIONN_SECRET_KEY=changeme-run-openssl-rand-hex-32
MODELIONN_REQUIRE_SIGNATURE_VERIFICATION=true

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_PASSWORD=changeme-generate-strong-password
MODELIONN_DATABASE_URL=postgresql+asyncpg://modelionn:${POSTGRES_PASSWORD}@postgres:5432/modelionn

# ── IPFS ─────────────────────────────────────────────────────
MODELIONN_IPFS_API_URL=http://ipfs:5001
MODELIONN_IPFS_GATEWAY_URL=http://ipfs:8080

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=changeme-redis-password
MODELIONN_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Celery ───────────────────────────────────────────────────
MODELIONN_CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
MODELIONN_CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

# ── Bittensor ────────────────────────────────────────────────
MODELIONN_BT_NETWORK=finney
MODELIONN_BT_NETUID=<your-registered-netuid>
MODELIONN_BT_WALLET_NAME=default
MODELIONN_BT_WALLET_HOTKEY=default
MODELIONN_MIN_STAKE_TO_PUBLISH=100.0

# ── Field Encryption (AES-256-GCM) ──────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MODELIONN_ENCRYPTION_KEY=changeme-generate-fernet-key

# ── CORS ─────────────────────────────────────────────────────
MODELIONN_CORS_ORIGINS=https://your-domain.com

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=changeme-run-openssl-rand-base64-32

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme-grafana-password
FLOWER_USER=admin
FLOWER_PASSWORD=changeme-flower-password

# ── Sentry (optional) ───────────────────────────────────────
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_RATE=0.1
# SENTRY_PROFILES_RATE=0.1

# ── Backup ───────────────────────────────────────────────────
# MODELIONN_BACKUP_RETAIN_DAYS=7
